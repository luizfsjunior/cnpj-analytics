# Copie para .env e ajuste se necessário.
# Dentro do docker compose use host "postgres"; do host use "localhost".
DATABASE_URL=postgres://cnpj:cnpj@localhost:5433/cnpj?sslmode=disable
PORT=8001

# --- Tuning da carga (analytics/load.sh) ------------------------------------
# Opcionais. O load.sh lê este .env automaticamente; valores passados na linha
# de comando (ex.: TUNE_RAM_GB=32 bash analytics/load.sh) têm prioridade.
# TUNE=1                  # 1 = aplica tuning de carga (default) | 0 = desliga
# TUNE_RAM_GB=6           # orçamento de RAM do load (default: 6). Pico ≈ 60%.
# MAX_PARALLEL_MAINT=4    # workers paralelos p/ criação de índices (default: 4)
# Sobrescrevem o cálculo automático (normalmente desnecessário):
# MAINT_WORK_MEM=737MB
# WORK_MEM=92MB
# MAX_WAL_SIZE=3GB
